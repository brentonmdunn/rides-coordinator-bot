# Discord token
TOKEN=

# CSV URL to the LSCC ppl file
LSCC_PPL_CSV_URL=

# Values: TRUE or FALSE
# If true, logs all reacts and unreacts to #bot-logs
LOG_ALL_REACTIONS=

# User ID of main rides coordinator for ask-rides messages
MAIN_RIDES_COORD_USER_ID=

# Gemini API key
GOOGLE_API_KEY=

# LSCC mastercalendar ICAL URL
ICAL_URL=

# Auth provider: "cloudflare" (default, keep during cutover) or "self" (Discord OAuth)
AUTH_PROVIDER=cloudflare

# Cloudflare Access Configuration (used when AUTH_PROVIDER=cloudflare)
CLOUDFLARE_TEAM_DOMAIN=
CLOUDFLARE_AUD=

# Discord OAuth (used when AUTH_PROVIDER=self)
# Reuse the existing bot's Discord application — add a redirect URI in the
# Discord developer portal under OAuth2 → Redirects.
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
DISCORD_OAUTH_REDIRECT_URI=https://yourdomain/api/auth/discord/callback

# Guild-role auto-provisioning (optional, used when AUTH_PROVIDER=self)
# If set, users with the ride coordinator Discord role are granted access
# automatically on first login without requiring a manual invite.
DISCORD_GUILD_ID=
DISCORD_RIDE_COORDINATOR_ROLE_ID=

# Frontend base URL for post-login redirect (used when AUTH_PROVIDER=self)
FRONTEND_BASE_URL=https://yourdomain

# Set to true to test the real Discord OAuth flow locally instead of the mock user bypass.
# Also requires: AUTH_PROVIDER=self, DISCORD_OAUTH_* vars, and
# http://localhost:8000/api/auth/discord/callback added to your Discord app's redirect URIs.
LOCAL_USE_DISCORD_OAUTH=false

# Discord channel ID for API messages
DISCORD_CHANNEL_ID=

# Discord channel ID for error messages
ERROR_CHANNEL_ID=

# Comma-separated list of admin emails
ADMIN_EMAILS=

# Redis URL (set in prod; local uses in-memory cache)
REDIS_URL=
