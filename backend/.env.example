# ── App ──────────────────────────────────────────────────────────────────────

# Environment name. Controls log level, cookie security, and dev shortcuts.
# Values: local | preprod | prod  (default: local)
APP_ENV=local

# SQLite database path. Defaults to sqlite+aiosqlite:///./db/bot.db
DATABASE_URL=

# Redis URL for caching. Falls back to in-memory cache when unset (local only).
REDIS_URL=

# Set to true to start the API without connecting to Discord (API-only mode).
DISABLE_DISCORD_BOT=false


# ── Discord Bot ───────────────────────────────────────────────────────────────

# Bot token from the Discord developer portal.
TOKEN=

# Channel ID where the bot posts ride coordination messages.
DISCORD_CHANNEL_ID=

# Channel ID where the bot reports unexpected errors.
ERROR_CHANNEL_ID=

# User ID of the main rides coordinator (used in ask-rides messages).
MAIN_RIDES_COORD_USER_ID=


# ── Authentication ────────────────────────────────────────────────────────────

# Auth provider. Values: cloudflare | self  (default: cloudflare)
AUTH_PROVIDER=cloudflare

# Comma-separated list of emails seeded as admins on startup.
ADMIN_EMAILS=

# Frontend base URL — used for post-login redirects (AUTH_PROVIDER=self).
FRONTEND_BASE_URL=https://yourdomain


# Cloudflare Access — required when AUTH_PROVIDER=cloudflare
CLOUDFLARE_TEAM_DOMAIN=
CLOUDFLARE_AUD=


# Discord OAuth — required when AUTH_PROVIDER=self
# Reuse the existing bot's Discord application. Add a redirect URI under
# OAuth2 → Redirects in the Discord developer portal.
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
DISCORD_OAUTH_REDIRECT_URI=https://yourdomain/api/auth/discord/callback

# Optional: grant access automatically to users with this Discord role
# instead of requiring a manual invite.
DISCORD_GUILD_ID=
DISCORD_RIDE_COORDINATOR_ROLE_ID=

# Set to true to test the real Discord OAuth flow locally.
# Requires AUTH_PROVIDER=self, DISCORD_OAUTH_* vars set, and
# http://localhost:8000/api/auth/discord/callback in your Discord app's redirect URIs.
LOCAL_USE_DISCORD_OAUTH=false


# Emergency bypass login — optional, AUTH_PROVIDER=self only
# Adds a password field to the login page when Discord OAuth is unavailable.
# Generate the hash: uv run python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
# See docs/bypass-login.md for full setup instructions.
BYPASS_DISCORD=false
BYPASS_PASSWORD=
BYPASS_EMAIL=bypass-emergency@local


# ── External Services ─────────────────────────────────────────────────────────

# CSV export URL for the LSCC people spreadsheet.
LSCC_PPL_CSV_URL=

# ICAL URL for the LSCC master calendar.
ICAL_URL=

# Google Gemini API key (read automatically by the Google GenAI SDK).
GOOGLE_API_KEY=
